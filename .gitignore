# Secrets
.env
.env.local
.env.*.local

# Nested git repos (preserve as content; do NOT track as submodules).
# legacy/p11-closed-v5-{mimo,minimax-m3}/ and victorchen96.github.io/
# each carry their own .git/ on disk for their local history. We embed
# them as plain content here so this monorepo is self-contained.
**/.git

