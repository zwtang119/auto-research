# AutoResearch framework — API credentials
#
# DO NOT commit a real .env. Copy this to .env (NOT tracked) and fill in.
# All experiment runners under experiments/ and watchdog scripts read from
# THIS file at auto-research/.env (project root).
#
# Source of truth for variable names: framework/vendor/experiment-config.yaml
# (`models:` and `api_endpoints:` sections). The vendor config expects these
# env names at runtime.

# ===== Default provider (matches policysim-research-Tsinghua config) =====
LLM_PROVIDER=openai
LLM_MODEL=DeepSeek-V4-Flash

# Paratera entrypoint (https://llmapi.paratera.com — OpenAI-compatible)
# PARATERA_API_KEY covers ALL models whose `provider: paratera` in
# framework/vendor/policysim_config/experiment-config.yaml.
# Smoke-tested 2026-07-04 via PARATERA_API_KEY (real key):
#   OK:  DeepSeek-V4-Pro, DeepSeek-V4-Flash, DeepSeek-V3.2,
#        kimi-k2.5, kimi-k2.6,
#        qwen3.5-122b, qwen3.5-122b-a10b, qwen3.6-plus,
#        minimax-m2.7, MiniMax-M3, glm-5.1, glm-4.5-air
#   403 (team not allowed): GLM-5.2, Qwen3.7-Plus, Qwen3.7-Max
PARATERA_API_KEY=
# OpenAI-compatible key for the same Paratera endpoint (alias — keep in sync).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://llmapi.paratera.com

# ===== Optional: OpenRouter (free tier) =====
# If you have OPENROUTER_API_KEY set, the following free models become available:
#   nvidia/nemotron-3-ultra-550b-a55b:free
#   nvidia/nemotron-3-super-120b-a12b:free
#   google/gemma-4-31b-it:free
#   openai/gpt-oss-120b:free
# Without this key, the `openrouter` provider in experiment-config.yaml will
# fail at runtime; runners that use it will be skipped.
# OPENROUTER_API_KEY=

# ===== Optional: Moonshot / Kimi direct =====
# KIMI_API_KEY=

# ===== Optional: Zhipu direct (separate from Paratera-routed glm) =====
# ZHIPU_API_KEY=

# ===== Operational knobs =====
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=65536
# DEEPSEEK_THINKING=true
# DEEPSEEK_REASONING_EFFORT=high

# ===== Optional: EIA (Energy Information Administration) for P1+P2 evidence =====
EIA_API_KEY=

# ===== Watchdog (Deli_AutoResearch §7 L1 cron) =====
# Hourly interval in seconds for staleness checks. 2h default per SKILL §7.
WATCHDOG_STALE_THRESHOLD_SECONDS=7200
# Hourly check shell — see framework/watchdog/hourly_check.sh

# ===== Review-model pinning (P12 M8, 2026-07-04) =====
# Distinct model_ids for the five-persona review (PIT-107 requires ≥3 distinct
# providers; this set uses 5 distinct model_ids all routed via Paratera):
#   R1 experimentalist  → deepseek-v4-pro
#   R2 theorist         → kimi-k2.5
#   R3 applied          → MiniMax-M3
#   R4 skeptical        → deepseek-v4-flash
#   R5 systems          → qwen3.5-122b-a10b
# No additional keys required — all five use PARATERA_API_KEY.